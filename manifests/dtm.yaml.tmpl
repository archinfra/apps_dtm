apiVersion: v1
kind: Namespace
metadata:
  name: __NAMESPACE__
  labels:
    app.kubernetes.io/name: dtm
    app.kubernetes.io/instance: __APP_NAME__
---
apiVersion: v1
kind: Secret
metadata:
  name: __APP_NAME__-store
  namespace: __NAMESPACE__
  labels:
    app.kubernetes.io/name: dtm
    app.kubernetes.io/instance: __APP_NAME__
type: Opaque
stringData:
  STORE_PASSWORD: "__STORE_PASS__"
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: __APP_NAME__-config
  namespace: __NAMESPACE__
  labels:
    app.kubernetes.io/name: dtm
    app.kubernetes.io/instance: __APP_NAME__
data:
  STORE_DRIVER: "__STORE_DRIVER__"
  STORE_HOST: "__STORE_HOST__"
  STORE_PORT: "__STORE_PORT__"
  STORE_USER: "__STORE_USER__"
  STORE_DB: "__STORE_DB__"
  STORE_SCHEMA: "__STORE_SCHEMA__"
  REDIS_PREFIX: "__REDIS_PREFIX__"
  DATA_EXPIRE: "__DATA_EXPIRE__"
  FINISHED_DATA_EXPIRE: "__FINISHED_DATA_EXPIRE__"
  HTTP_PORT: "__HTTP_PORT__"
  GRPC_PORT: "__GRPC_PORT__"
  JSONRPC_PORT: "__JSONRPC_PORT__"
  MICRO_SERVICE_END_POINT: "__MICRO_SERVICE_END_POINT__"
  TRANS_CRON_INTERVAL: "__TRANS_CRON_INTERVAL__"
  TIMEOUT_TO_FAIL: "__TIMEOUT_TO_FAIL__"
  RETRY_INTERVAL: "__RETRY_INTERVAL__"
  REQUEST_TIMEOUT: "__REQUEST_TIMEOUT__"
  LOG_LEVEL: "__LOG_LEVEL__"
  ADMIN_BASE_PATH: "__ADMIN_BASE_PATH__"
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: __APP_NAME__
  namespace: __NAMESPACE__
  labels:
    app.kubernetes.io/name: dtm
    app.kubernetes.io/instance: __APP_NAME__
spec:
  replicas: __REPLICAS__
  selector:
    matchLabels:
      app.kubernetes.io/name: dtm
      app.kubernetes.io/instance: __APP_NAME__
  template:
    metadata:
      labels:
        app.kubernetes.io/name: dtm
        app.kubernetes.io/instance: __APP_NAME__
    spec:
      containers:
        - name: dtm
          image: __IMAGE__
          imagePullPolicy: __IMAGE_PULL_POLICY__
          ports:
            - name: http
              containerPort: __HTTP_PORT__
            - name: grpc
              containerPort: __GRPC_PORT__
            - name: jsonrpc
              containerPort: __JSONRPC_PORT__
          envFrom:
            - configMapRef:
                name: __APP_NAME__-config
          env:
            - name: STORE_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: __APP_NAME__-store
                  key: STORE_PASSWORD
          readinessProbe:
            tcpSocket:
              port: http
            initialDelaySeconds: 5
            periodSeconds: 5
            timeoutSeconds: 2
            failureThreshold: 12
          livenessProbe:
            tcpSocket:
              port: http
            initialDelaySeconds: 20
            periodSeconds: 10
            timeoutSeconds: 2
            failureThreshold: 6
          resources:
            requests:
              cpu: __REQUEST_CPU__
              memory: __REQUEST_MEMORY__
            limits:
              cpu: __LIMIT_CPU__
              memory: __LIMIT_MEMORY__
---
apiVersion: v1
kind: Service
metadata:
  name: __APP_NAME__
  namespace: __NAMESPACE__
  labels:
    app.kubernetes.io/name: dtm
    app.kubernetes.io/instance: __APP_NAME__
spec:
  type: __SERVICE_TYPE__
  selector:
    app.kubernetes.io/name: dtm
    app.kubernetes.io/instance: __APP_NAME__
  ports:
    - name: http
      port: __HTTP_PORT__
      targetPort: http
      __HTTP_NODE_PORT_LINE__
    - name: grpc
      port: __GRPC_PORT__
      targetPort: grpc
      __GRPC_NODE_PORT_LINE__
    - name: jsonrpc
      port: __JSONRPC_PORT__
      targetPort: jsonrpc
      __JSONRPC_NODE_PORT_LINE__
